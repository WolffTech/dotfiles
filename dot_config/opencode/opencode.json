{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": [
    "btw-opencode",
    "@ramtinj95/opencode-tokenscope"
  ],
  "provider": {
    "lmstudio": {
      "api": "openai",
      "name": "LM Studio",
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma 4 26B A4B"
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "lm-studio"
      }
    }
  },
  "agent": {
    "plan": {
      "color": "#df8e1d",
      "permission": {
        "skill": {
          "brainstorming": "deny",
          "dispatching-parallel-agents": "deny",
          "executing-plans": "deny",
          "finishing-a-development-branch": "deny",
          "receiving-code-review": "deny",
          "requesting-code-review": "deny",
          "subagent-driven-development": "deny",
          "systematic-debugging": "deny",
          "test-driven-development": "deny",
          "using-git-worktrees": "deny",
          "using-superpowers": "deny",
          "verification-before-completion": "deny",
          "writing-plans": "deny",
          "writing-skills": "deny"
        }
      }
    },
    "build": {
      "color": "#d20f39",
      "permission": {
        "skill": {
          "brainstorming": "deny",
          "dispatching-parallel-agents": "deny",
          "executing-plans": "deny",
          "finishing-a-development-branch": "deny",
          "receiving-code-review": "deny",
          "requesting-code-review": "deny",
          "subagent-driven-development": "deny",
          "systematic-debugging": "deny",
          "test-driven-development": "deny",
          "using-git-worktrees": "deny",
          "using-superpowers": "deny",
          "verification-before-completion": "deny",
          "writing-plans": "deny",
          "writing-skills": "deny"
        }
      }
    },
    "Super Plan": {
      "description": "Plan with Superpowers workflows enabled by default",
      "mode": "primary",
      "color": "#df8e1d",
      "prompt": "You are the OpenCode Plan agent with Superpowers enabled. Before responding to any user request, load the using-superpowers skill with the skill tool, then follow it. If the using-superpowers skill is already loaded in this session, do not load it again; continue following it. Preserve the normal Plan agent behavior: analyze, propose plans, and avoid file modifications unless the user explicitly asks and permissions allow."
    },
    "Super Build": {
      "description": "Build with Superpowers workflows enabled by default",
      "mode": "primary",
      "color": "#d20f39",
      "prompt": "You are the OpenCode Build agent with Superpowers enabled. Before responding to any user request, load the using-superpowers skill with the skill tool, then follow it. If the using-superpowers skill is already loaded in this session, do not load it again; continue following it. Preserve the normal Build agent behavior: implement requested changes pragmatically, verify work, and use tools as needed."
    },
    "Research": {
      "description": "General Research Agent",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "prompt": "You are a research agent. Find current, source-backed answers. Be concise and cite sources.",
      "color": "#1e66f5",
      "tools": {
        "*": false,
        "websearch": true,
        "webfetch": true,
        "gh_grep_*": true,
        "microsoft-learn_*": true,
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "skill": "deny",
        "task": "deny",
        "todowrite": "deny",
        "question": "deny"
      }
    },
    "Analyze": {
      "color": "#8839ef"
    },
    "Ticket": {
      "color":"#40a02b"
    },
    "KB": {
      "color": "#2f6f3e"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    }
  }
}
