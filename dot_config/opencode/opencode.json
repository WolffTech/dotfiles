{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "provider": {
    "lmstudio": {
      "api": "openai",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "lm-studio"
      },
    }
  },
  "agent": {
    "plan": {
      "color": "#df8e1d"
    },
    "build": {
      "color": "#d20f39"
    },
    "research": {
      "description": "General research agent for answering questions without making changes",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "color": "#1e66f5",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "analyze": {
      "description": "Analyzes documents and code - extracts info, reviews grammar/spelling, explains architecture and readability",
      "mode": "primary",
      "model": "openai/gpt-5.4",
      "color": "#8839ef",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "Ticket": {
      "color":"#40a02b"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    }
  }
}
