{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "btw-opencode"
  ],
  "provider": {
    "lmstudio": {
      "api": "openai",
      "name": "LM Studio",
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma 4 26B A4B"
        }
      },
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1",
        "apiKey": "lm-studio"
      },
    }
  },
  "agent": {
    "plan": {
      "color": "#df8e1d"
    },
    "build": {
      "color": "#d20f39"
    },
    "Research": {
      "description": "General Research Agent",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "temperature": 0.1,
      "prompt": "You are a research agent. Find current, source-backed answers. Be concise and cite sources.",
      "color": "#1e66f5",
      "tools": {
        "*": false,
        "websearch": true,
        "webfetch": true,
        "gh_grep_*": true,
        "microsoft-learn_*": true,
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "skill": "deny",
        "task": "deny",
        "todowrite": "deny",
        "question": "deny"
      }
    },
    "Analyze": {
      "color": "#8839ef"
    },
    "Ticket": {
      "color":"#40a02b"
    },
    "KB": {
      "color": "#2f6f3e"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "microsoft-learn": {
      "type": "remote",
      "url": "https://learn.microsoft.com/api/mcp",
      "enabled": true
    }
  }
}
