# Set the directory for zinit and plugins
ZINIT_HOME="$HOME/.local/share/zinit/zinit"

# Download Zinit when possible. Missing git should not break shell startup.
if [[ ! -d "$ZINIT_HOME" ]] && command -v git >/dev/null 2>&1; then
	mkdir -p "$(dirname "$ZINIT_HOME")"
	git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
fi

# Source/load zinit and plugins when available.
if [[ -r "$ZINIT_HOME/zinit.zsh" ]]; then
	source "$ZINIT_HOME/zinit.zsh"
	zinit light zsh-users/zsh-syntax-highlighting
	zinit light zsh-users/zsh-completions
	zinit light zsh-users/zsh-autosuggestions
	zinit light Aloxaf/fzf-tab
fi

# Platform detection
case "${OSTYPE:-}" in
	darwin*) IS_MACOS=1 ;;
	*) IS_MACOS=0 ;;
esac

# Set Path Parameters
_add_path_if_exists() {
	local dir="$1"
	[[ -d "$dir" ]] && path=("$dir" $path)
}

_add_path_if_exists /sbin
_add_path_if_exists /usr/sbin
_add_path_if_exists /bin
_add_path_if_exists /usr/bin
_add_path_if_exists /usr/local/sbin
_add_path_if_exists /usr/local/bin
_add_path_if_exists /home/linuxbrew/.linuxbrew/sbin
_add_path_if_exists /home/linuxbrew/.linuxbrew/bin
_add_path_if_exists /opt/homebrew/sbin
_add_path_if_exists /opt/homebrew/bin
_add_path_if_exists "$HOME/.local/bin"
_add_path_if_exists "$HOME/bin"

# Oh my Posh
if [[ "$TERM_PROGRAM" != "Apple Terminal" ]] && command -v oh-my-posh >/dev/null 2>&1; then
	eval "$(oh-my-posh init zsh --config "$HOME/.config/ohmyposh/config.json")"
fi

# Load completions
autoload -U compinit && compinit

# Completion styling
zstyle ':completion:*:git-checkout:*' sort false
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
zstyle ':completion:*' menu no
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept
zstyle ':fzf-tab:*' use-fzf-default-opts yes
zstyle ':fzf-tab:*' switch-group '<' '>'

# History
HISTSIZE=5000
HISTFILE=~/.zsh_history
SAVEHIST=$HISTSIZE
HISTDUP=erase
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups

# Python aliases
if [[ -x /opt/homebrew/bin/python3 ]]; then
	alias python3='/opt/homebrew/bin/python3'
fi

if command -v python3.11 >/dev/null 2>&1; then
	alias python='python3.11'
fi

#Tmux Alias
alias t='tmux'
alias tc='tmux new-session -t 0'
alias tk='tmux kill-session'
alias td='tmux detach'
alias ta='tmux attach'
alias tla='tmux ls'
alias tmain='tmux new-session -d -s main -n worklog "nvim ~/Documents/worklog.md; zsh -i" \; \
new-window -n btop "btop; zsh -i" \; \
new-window -n git "lazygit; zsh -i" \; \
new-window -n vim "cd ~/Developer/git && nvim; zsh -i" \; \
attach -t main'
alias tcmain='tmux new-session -t main'
alias tfloat='tmux new-session -d -s float -n clipboard "nvim ~/temp.md; zsh -i" \; \
new-window -n zsh "zsh -i" \; \
attach -t float'

# Folder aliases
if (( IS_MACOS )) && command -v open >/dev/null 2>&1; then
	alias .='open .'
fi
alias personal='cd ~/git/personal-nickwolff'
alias worklog='nvim ~/Documents/worklog.md'

# Other aliases
alias oc='opencode'
alias lg='lazygit'
alias lazyd='lazydocker'
if command -v eza >/dev/null 2>&1; then
	alias ls='eza'
	alias la='eza -l -a -g --icons'
	alias ll='eza -l -g --icons'
fi
alias vi='nvim'
if command -v numi-cli >/dev/null 2>&1; then
	alias calc='numi-cli'
fi
if command -v qlmanage >/dev/null 2>&1; then
	alias photo='qlmanage -p'
fi

# Neovim System Clipboard Editor
if command -v pbpaste >/dev/null 2>&1 && command -v pbcopy >/dev/null 2>&1; then
	alias cb='tmp=$(mktemp) && pbpaste > "$tmp" && nvim "$tmp" && pbcopy < "$tmp" && rm "$tmp"'
fi

# Terraform alias
alias tf='terraform'

# vim mode
set -o vi

# Shell integrations
if [[ -t 0 ]] && command -v fzf >/dev/null 2>&1; then
	eval "$(fzf --zsh)"
	bindkey '^Y' fzf-file-widget
fi

# The Fuck Alias (Command Line AutoCorrect)
if command -v thefuck >/dev/null 2>&1; then
	eval "$(thefuck --alias)"
fi

# Zoxide startup and rebind
if command -v zoxide >/dev/null 2>&1; then
	eval "$(zoxide init --cmd cd zsh)"
fi

# Unbind ^T from teletype. The "status" control character is BSD/macOS-only.
if (( IS_MACOS )) && [[ -t 0 ]]; then
	stty status undef
fi

# Switch Cat with Bat
if command -v bat >/dev/null 2>&1; then
	alias cat='bat --paging=never'
fi

# Restore cursor to blinking underline before each prompt. nvim emits a
# hardcoded \E[2 q (steady block) on exit (neovim/neovim#4396) that bypasses
# terminfo, so this is the only reliable place to undo it.
_restore_cursor() { printf '\e[3 q' }
precmd_functions+=(_restore_cursor)
